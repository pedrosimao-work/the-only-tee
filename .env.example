FLASK_APP=run.py  # Tell Flask which file starts the application
FLASK_ENV=development  # Tell Flask this is a local development environment
SECRET_KEY=change-this-secret-key  # Store the secret key used for sessions and security
DATABASE_URL=sqlite:///the_only_drop.db  # Store the local development database connection string
PRINTIFY_API_BASE_URL=https://api.printify.com/v1  # Store the Printify API base URL
PRINTIFY_API_TOKEN=your-printify-api-token  # Store the Printify API token for local development
PRINTIFY_SHOP_ID=your-printify-shop-id  # Store the Printify shop ID connected to this project