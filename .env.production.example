FLASK_APP=run.py # Tell Flask which file starts the application
FLASK_ENV=production # Tell Flask this is the production environment
SECRET_KEY=replace-with-a-long-random-production-secret # Store a secure production secret key
DATABASE_URL=mysql+pymysql://database_user:database_password@localhost/database_name # Store the DirectAdmin MariaDB connection string
PRINTIFY_API_BASE_URL=https://api.printify.com/v1 # Store the Printify API base URL
PRINTIFY_API_TOKEN=replace-with-production-printify-api-token # Store the production Printify API token
PRINTIFY_SHOP_ID=replace-with-production-printify-shop-id # Store the production Printify shop ID